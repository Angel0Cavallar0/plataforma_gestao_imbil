# Públicas (client + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apenas server — configurar na Vercel (Production + Preview)
SUPABASE_SERVICE_ROLE_KEY=

# URL canônica da aplicação (links nos e-mails do Supabase Auth)
# Produção: https://plataforma.imbil.com.br
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E-mails são enviados pelo Supabase Auth (templates "Invite user" e "Reset password").
# No painel Supabase → Authentication → URL Configuration:
# - Site URL: https://plataforma.imbil.com.br
# - Redirect URLs (adicione as URLs EXATAS, não só wildcard):
#   https://plataforma.imbil.com.br/cadastrar-senha
#   https://plataforma.imbil.com.br/trocar-senha
#   https://plataforma.imbil.com.br/auth/callback
#   https://plataforma.imbil.com.br/auth/confirm
#   https://plataforma.imbil.com.br/auth/complete
# (e equivalentes em localhost para desenvolvimento)

# Marketing / Meta Graph API
META_GRAPH_API_VERSION=v21.0

# Cron de publicação agendada — Supabase Edge Function (não usa Vercel Cron)
# 1. Deploy: supabase functions deploy publish-scheduled-posts --no-verify-jwt
# 2. Secrets na Edge Function (Dashboard → Edge Functions → publish-scheduled-posts → Secrets):
#    CRON_SECRET=<gere um valor aleatório>
#    META_GRAPH_API_VERSION=v21.0
#    (SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY são injetados automaticamente)
# 3. Vault (SQL, uma vez): armazene a service role para o pg_cron invocar a função:
#    SELECT marketing.store_vault_secret(
#      'cron_service_role_key',
#      '<cole aqui a SUPABASE_SERVICE_ROLE_KEY>',
#      'Auth pg_cron → Edge publish-scheduled-posts'
#    );
# 4. Aplique a migration 009_marketing_publish_cron.sql (pg_cron a cada 5 min)
# Teste manual: curl -X POST "https://<project>.supabase.co/functions/v1/publish-scheduled-posts" \
#   -H "Authorization: Bearer <CRON_SECRET>"

# Opcional: rota Next.js para disparo manual em dev (mesmo CRON_SECRET)
CRON_SECRET=

# Se /cadastrar-senha não estiver na lista, o Supabase usa só o Site URL e o link quebra.
# Configure também SMTP customizado em Authentication → Emails se não usar o provedor padrão.
