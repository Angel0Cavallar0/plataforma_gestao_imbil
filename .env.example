# Públicas (client + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apenas server — configurar na Vercel (Production + Preview)
SUPABASE_SERVICE_ROLE_KEY=

# URL canônica da aplicação (links nos e-mails do Supabase Auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# E-mails são enviados pelo Supabase Auth (templates "Invite user" e "Reset password").
# No painel Supabase → Authentication → URL Configuration, adicione em Redirect URLs:
#   http://localhost:3000/cadastrar-senha
#   http://localhost:3000/trocar-senha
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/confirm
# (e as mesmas URLs com o domínio de produção)
# Configure também SMTP customizado em Authentication → Emails se não usar o provedor padrão.
